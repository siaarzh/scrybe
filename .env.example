# --- OpenAI (default) ---
OPENAI_API_KEY=sk-...

# --- Voyage AI (voyage-code-3, code-optimized) ---
# Uncomment to use instead of OpenAI. First 200M tokens free (payment method required to unlock standard rate limits).
# EMBEDDING_API_KEY=pa-...
# EMBEDDING_BASE_URL=https://api.voyageai.com/v1
# EMBEDDING_MODEL=voyage-code-3
# EMBEDDING_DIMENSIONS=1024

# --- Mistral ---
# EMBEDDING_API_KEY=...
# EMBEDDING_BASE_URL=https://api.mistral.ai/v1
# EMBEDDING_MODEL=mistral-embed
# EMBEDDING_DIMENSIONS=1024

# --- Self-hosted (Ollama, LocalAI, LM Studio, etc.) ---
# EMBEDDING_API_KEY=any        # set to any non-empty string if no auth required
# EMBEDDING_BASE_URL=http://localhost:11434/v1
# EMBEDDING_MODEL=nomic-embed-text    # model name as served by your instance
# EMBEDDING_DIMENSIONS=768            # must match the model's actual output

# --- Reranking (optional, improves result quality) ---
# Set SCRYBE_RERANK=true to enable. Reranks top candidates before returning results.
#
# Voyage AI (auto-detected when EMBEDDING_BASE_URL is Voyage — just set the flag):
# SCRYBE_RERANK=true
# SCRYBE_RERANK_MODEL=rerank-2.5        # optional override, defaults to rerank-2.5
#
# Custom reranker (any provider):
# SCRYBE_RERANK=true
# SCRYBE_RERANK_BASE_URL=https://api.example.com/v1/rerank
# SCRYBE_RERANK_MODEL=rerank-model-name
# SCRYBE_RERANK_API_KEY=...             # optional, falls back to EMBEDDING_API_KEY
#
# SCRYBE_RERANK_FETCH_MULTIPLIER=5      # candidates = topK × multiplier (default 5)

# --- Hybrid search (BM25 + vector, on by default) ---
# Runs BM25 full-text search alongside vector search and merges results with RRF.
# Set to false to use vector-only search (pre-v0.4 behavior).
# SCRYBE_HYBRID=false
#
# RRF merge constant — higher = less sensitive to rank position (default 60)
# SCRYBE_RRF_K=60

# --- Text embedding (knowledge sources: GitLab issues, webpages, etc.) ---
# Used by search_knowledge. Falls back to EMBEDDING_* config if not set.
# Recommended: voyage-3 (multilingual) or voyage-multilingual-2 for issue text.
# SCRYBE_TEXT_EMBEDDING_BASE_URL=https://api.voyageai.com/v1
# SCRYBE_TEXT_EMBEDDING_MODEL=voyage-3
# SCRYBE_TEXT_EMBEDDING_API_KEY=pa-...   # falls back to EMBEDDING_API_KEY
# SCRYBE_TEXT_EMBEDDING_DIMENSIONS=1024

# --- Tuning (optional) ---
# EMBED_BATCH_SIZE=100
# EMBED_BATCH_DELAY_MS=0
