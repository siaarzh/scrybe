# scrybe environment configuration — reference / advanced users only.
#
# scrybe defaults to a fully local embedder (Xenova/multilingual-e5-small,
# 384d, ~80MB on first run, no API key required). The `scrybe init` wizard
# handles provider setup and writes any needed config — you only need to
# touch this file directly if you want to bypass the wizard, run in CI, or
# tune advanced behavior.
#
# Full env-var reference: docs/configuration.md

# ─── Embedding provider (default: local — no config) ──────────────────────────

# Local embedder (default). Nothing to set. Override the model only if you've
# benchmarked something better:
# SCRYBE_LOCAL_EMBEDDER=Xenova/multilingual-e5-small

# Voyage AI — voyage-code-3 (recommended for code quality, first 200M tokens free):
# EMBEDDING_API_KEY=pa-...
# EMBEDDING_BASE_URL=https://api.voyageai.com/v1
# EMBEDDING_MODEL=voyage-code-3
# EMBEDDING_DIMENSIONS=1024

# OpenAI:
# OPENAI_API_KEY=sk-...
# (or use the unified vars below — same effect)
# EMBEDDING_API_KEY=sk-...
# EMBEDDING_BASE_URL=https://api.openai.com/v1
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_DIMENSIONS=1536

# Mistral:
# EMBEDDING_API_KEY=...
# EMBEDDING_BASE_URL=https://api.mistral.ai/v1
# EMBEDDING_MODEL=mistral-embed
# EMBEDDING_DIMENSIONS=1024

# Self-hosted (Ollama, LocalAI, LM Studio, etc.):
# EMBEDDING_API_KEY=any                  # any non-empty string if no auth
# EMBEDDING_BASE_URL=http://localhost:11434/v1
# EMBEDDING_MODEL=nomic-embed-text       # model name as served by your instance
# EMBEDDING_DIMENSIONS=768               # must match the model's actual output

# ─── Text embedding for knowledge sources (GitLab issues, webpages) ───────────
# Used by `search knowledge`. Falls back to EMBEDDING_* config if not set.
# Recommended: voyage-3 (multilingual) for issue text in mixed languages.
# SCRYBE_TEXT_EMBEDDING_BASE_URL=https://api.voyageai.com/v1
# SCRYBE_TEXT_EMBEDDING_MODEL=voyage-3
# SCRYBE_TEXT_EMBEDDING_API_KEY=pa-...   # falls back to EMBEDDING_API_KEY
# SCRYBE_TEXT_EMBEDDING_DIMENSIONS=1024

# ─── Reranking (optional, improves result quality) ────────────────────────────
# Voyage AI (auto-detected when EMBEDDING_BASE_URL is Voyage — just set the flag):
# SCRYBE_RERANK=true
# SCRYBE_RERANK_MODEL=rerank-2.5         # optional override
#
# Custom reranker (any provider):
# SCRYBE_RERANK=true
# SCRYBE_RERANK_BASE_URL=https://api.example.com/v1/rerank
# SCRYBE_RERANK_MODEL=rerank-model-name
# SCRYBE_RERANK_API_KEY=...              # optional, falls back to EMBEDDING_API_KEY
# SCRYBE_RERANK_FETCH_MULTIPLIER=5       # candidates = topK × multiplier (default 5)

# ─── Hybrid search (BM25 + vector) ────────────────────────────────────────────
# Hybrid is on by default. RRF merges BM25 and vector results.
# SCRYBE_HYBRID=false                    # vector-only (pre-v0.4 behavior)
# SCRYBE_RRF_K=60                        # higher = less rank-position sensitive

# ─── Daemon control (CI / scripted environments) ──────────────────────────────
# By default the MCP server auto-spawns a daemon on first agent invocation
# (on-demand mode, M-D11.1). For CI runs that should not spawn background
# processes:
# SCRYBE_NO_AUTO_DAEMON=1

# ─── CLI behavior (CI / scripted environments) ────────────────────────────────
# Silence the v1.0-removal deprecation notices that print on stderr when an
# old CLI alias is used (e.g. `scrybe add-project`). Useful in CI logs.
# SCRYBE_NO_DEPRECATION_WARNING=1

# ─── Storage location ─────────────────────────────────────────────────────────
# Override the default DATA_DIR (Windows: %LOCALAPPDATA%\scrybe\scrybe;
# macOS: ~/Library/Application Support/scrybe; Linux: ~/.local/share/scrybe).
# SCRYBE_DATA_DIR=/path/to/custom/dir

# ─── Tuning (advanced) ────────────────────────────────────────────────────────
# Most users never need these. Defaults are usually correct.

# Chunker:
# SCRYBE_CHUNK_SIZE=1500                 # max chars per chunk
# SCRYBE_CHUNK_OVERLAP=200               # chars of overlap between chunks
# SCRYBE_MAX_FILE_BYTES=524288           # skip files larger than this (default 512KB)

# Indexer:
# SCRYBE_SCAN_CONCURRENCY=32             # parallel file-hashing streams

# Embedder batch sizing (post-M-D10):
# As of v0.21.0, batch size is auto-tuned per (project, source, provider, model)
# via convergent halving — state persists in DATA_DIR/embed-batch-state.json.
# EMBED_BATCH_SIZE acts as the initial *ceiling* for the binary search, not a
# fixed batch size. Increase only if you trust your provider's per-request cap;
# leave at default for hands-off operation.
# EMBED_BATCH_SIZE=100
# EMBED_BATCH_DELAY_MS=0                 # ms delay between batches (rate limit)
